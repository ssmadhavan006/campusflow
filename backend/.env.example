PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campusflow_db?schema=public

# Generate unique secrets per environment using: openssl rand -hex 64
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_64_char_hex_string
JWT_VERIFICATION_SECRET=change_me_to_another_random_64_char_hex_string
JWT_RESET_SECRET=change_me_to_yet_another_random_64_char_hex_string
QR_SECRET=change_me_to_a_random_64_char_hex_string

# Set these to your actual deployment URLs in production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Comma-separated list of emails bootstrapped as ADMIN on first registration/seed
ADMIN_EMAILS=admin@example.com

# Google OAuth client ID (required for Google Sign-In)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

DISABLE_AUTO_OD_GENERATION=false
UPLOAD_DIR=uploads
